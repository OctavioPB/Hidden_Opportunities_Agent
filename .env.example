# Copy this file to .env and fill in values
# In demo mode, most of these are unused — the agent routes all I/O to local files

# --- Demo toggle ---
DEMO_MODE=true

# --- LLM (Sprint 3+) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai          # openai | anthropic | local
LLM_MODEL=gpt-3.5-turbo      # gpt-3.5-turbo | gpt-4 | claude-haiku-4-5-20251001

# --- Database ---
DB_PATH=data/db/opportunities.db

# --- Notifications (Sprint 2) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# --- Email (Sprint 4) ---
SENDGRID_API_KEY=SG....
EMAIL_FROM=agent@youragency.com

# --- Calendar (Sprint 4) ---
GOOGLE_CALENDAR_CREDENTIALS_PATH=secrets/google_calendar_creds.json

# --- Payments (Sprint 7) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- CRM (Sprint 2 — in production only) ---
HUBSPOT_API_KEY=...
PIPEDRIVE_API_KEY=...
